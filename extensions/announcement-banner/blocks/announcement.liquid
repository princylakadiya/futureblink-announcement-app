{% if shop.metafields.my_app.announcement != blank %}
<div id="announcement-banner" style="
  background-color: #1a1a2e;
  color: #ffffff;
  text-align: center;
  padding: 12px 20px;
  font-size: 16px;
  font-weight: bold;
  width: 100%;
  position: fixed;
  top: 0;
  left: 0;
  z-index: 9999;
">
  {{ shop.metafields.my_app.announcement.value }}
</div>

<style>
  body {
    margin-top: 48px !important;
  }
</style>
{% endif %}

{% schema %}
{
  "name": "Announcement Banner",
  "target": "body",
  "settings": []
}
{% endschema %}
